{
  "hpath": [
    "$HPM_PACKAGE_ROOT/otls"
  ],
  "env": [
    {
      "PYTHONPATH": {
        "method": "prepend",
        "value": "$HPM_PACKAGE_ROOT/python"
      }
    },
    {
      "HOUDINI_SCRIPT_PATH": {
        "method": "prepend",
        "value": "$HPM_PACKAGE_ROOT/scripts"
      }
    }
  ],
  "enable": "houdini_version >= '19.5' and houdini_version <= '21.0'",
  "requires": null,
  "recommends": null
}