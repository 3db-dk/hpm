{
  "permissions": {
    "allow": [
      "Task(*)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(rust-analyzer *)",
      "Bash(clippy *)",
      "Bash(rustfmt *)",
      "Bash(cargo-audit *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git add)",
      "Bash(git commit)",
      "Bash(git push)",
      "Read(**/*.rs)",
      "Read(**/*.md)",
      "Read(**/*.toml)",
      "Read(**/*.json)",
      "Read(**/CLAUDE.md)",
      "Write(**/*.rs)",
      "Edit(**/*.rs)",
      "MultiEdit(**/*.rs)",
      "Write(**/*.toml)",
      "Edit(**/*.toml)",
      "Write(**/*.md)",
      "Edit(**/*.md)",
      "Glob(**)",
      "Grep(**)",
      "LS(**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "TodoWrite(*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Read(**/credentials*)",
      "Read(**/private*)",
      "Write(./.env*)",
      "Edit(./.env*)",
      "Write(./secrets/**)",
      "Edit(./secrets/**)"
    ]
  },
  "model": "claude-3-5-sonnet-20241022",
  "env": {
    "HPM_DEV": "1",
    "HPM_PROJECT_PATH": "C:\\Users\\tumblehead\\Documents\\workspace\\hpm"
  },
  "agents": {
    "general-purpose": {
      "description": "General research and multi-step task execution",
      "tools": ["*"],
      "model": "claude-3-5-sonnet-20241022"
    },
    "rust-formatter": {
      "description": "Code formatting and style enforcement",
      "tools": ["Read", "Edit", "MultiEdit", "Bash"],
      "model": "claude-3-5-haiku-20241022"
    },
    "rust-developer": {
      "description": "Feature development and dependency management", 
      "tools": ["Read", "Write", "Edit", "MultiEdit", "Bash", "Grep", "Glob"],
      "model": "claude-3-5-sonnet-20241022"
    },
    "test-specialist": {
      "description": "Test implementation and quality assurance",
      "tools": ["Read", "Write", "Edit", "MultiEdit", "Bash"],
      "model": "claude-3-5-sonnet-20241022"
    },
    "documentation-writer": {
      "description": "Technical documentation and API documentation",
      "tools": ["Read", "Write", "Edit", "MultiEdit"],
      "model": "claude-3-5-haiku-20241022"
    },
    "architecture-advisor": {
      "description": "System design and architectural decisions",
      "tools": ["Read", "Glob", "Grep", "WebSearch", "WebFetch"],
      "model": "claude-opus-4-1-20250805"
    },
    "performance-specialist": {
      "description": "Performance analysis and optimization",
      "tools": ["Read", "Bash", "Grep", "Glob"],
      "model": "claude-3-5-sonnet-20241022"
    },
    "security-auditor": {
      "description": "Security analysis and vulnerability scanning",
      "tools": ["Read", "Bash", "Grep", "WebSearch"],
      "model": "claude-3-5-sonnet-20241022"
    }
  },
  "hooks": {
    "pre-edit": {
      "command": "cargo clippy --manifest-path $WORKSPACE/Cargo.toml -- -D warnings",
      "description": "Lint check before editing Rust files",
      "patterns": ["**/*.rs"]
    },
    "post-edit": {
      "command": "cargo fmt --manifest-path $WORKSPACE/Cargo.toml",
      "description": "Auto-format Rust files after editing",
      "patterns": ["**/*.rs"]
    },
    "pre-commit": {
      "command": "cargo test --manifest-path $WORKSPACE/Cargo.toml",
      "description": "Run tests before allowing commits",
      "cwd": "C:\\Users\\tumblehead\\Documents\\workspace\\hpm"
    }
  }
}