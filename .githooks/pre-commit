#!/usr/bin/env bash
# Fast quality gates before a commit lands. Mirror of `just pre-commit`
# (kept self-contained so contributors don't need `just` on PATH; if you
# change the gates here, update the `pre-commit` recipe in justfile too).

set -euo pipefail

# Run from the repo root regardless of where `git commit` was invoked.
cd "$(git rev-parse --show-toplevel)"

cargo fmt --all -- --check
cargo clippy --workspace --all-targets -- -D warnings
